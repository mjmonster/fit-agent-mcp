# ---- Server A: fitness-mcp (MCP server) ----
# JWT signing secret shared by the issuer and the verify middleware.
# REQUIRED — no default in code. Generate your own for local dev.
FITNESS_MCP_JWT_SECRET=change-me-dev-only

FITNESS_MCP_DB_PATH=fitness.db
FITNESS_MCP_HOST=127.0.0.1
FITNESS_MCP_PORT=8000

# ---- Server B: coach-agent (MCP host + client) ----
COACH_AGENT_SERVER_URL=http://127.0.0.1:8000/mcp
COACH_AGENT_MODEL=claude-haiku-4-5

# Per-user bearer token minted via: fitness-mcp issue-token --sub user_001 --scopes ...
# Server B only HOLDS a token; it never sees FITNESS_MCP_JWT_SECRET.
COACH_AGENT_TOKEN=

# Tier-3 live evals only (never needed by CI)
ANTHROPIC_API_KEY=
